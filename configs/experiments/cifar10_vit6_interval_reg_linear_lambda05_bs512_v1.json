{
  "experiment_name": "cifar10-vit6-interval-linear-lambda05-bs512-v1",
  "task_type": "vision_classification",
  "seed": 42,
  "dataset": {
    "name": "cifar10",
    "data_root": "data/raw/cifar10",
    "num_classes": 10,
    "image_size": 32,
    "mean": [0.4914, 0.4822, 0.4465],
    "std": [0.247, 0.2435, 0.2616]
  },
  "model": {
    "architecture": "vit",
    "image_size": 32,
    "patch_size": 4,
    "num_channels": 3,
    "hidden_size": 384,
    "num_hidden_layers": 6,
    "num_attention_heads": 6,
    "intermediate_size": 1536,
    "hidden_dropout_prob": 0.0,
    "attention_dropout_prob": 0.0
  },
  "initialization": {
    "query_key": "standard"
  },
  "training": {
    "max_epochs": 500,
    "per_device_batch_size": 512,
    "gradient_accumulation_steps": 1,
    "effective_batch_size": 512,
    "learning_rate": 0.003,
    "weight_decay": 0.05,
    "beta1": 0.9,
    "beta2": 0.999,
    "warmup_epochs": 30,
    "warmup_start_factor": 0.033,
    "num_workers": 4,
    "label_smoothing": 0.01,
    "use_amp": true,
    "eval_every_epochs": 1
  },
  "regularization": {
    "enabled": true,
    "type": "interval_asymmetry_ratio",
    "penalty": "linear_hinge",
    "lambda": 0.5,
    "interval_config": "configs/priors/cifar10_vit6_manual_band_smoke_custom_v1.json",
    "schedule": [
      {
        "epoch_start": 1,
        "epoch_end": 500,
        "every_n_epochs": 1
      }
    ]
  },
  "instrumentation": {
    "measure_training_time": true,
    "measure_flops": true,
    "exclude_analysis_time": true,
    "exclude_analysis_flops": true
  }
}
