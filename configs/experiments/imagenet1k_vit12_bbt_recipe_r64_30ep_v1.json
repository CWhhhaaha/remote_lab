{
  "experiment_name": "imagenet1k-vit12-bbt-recipe-r64-30ep-v1",
  "task_type": "vision_classification_recipe",
  "seed": 42,
  "dataset": {
    "name": "imagenet1k",
    "data_root": "data/raw/imagenet1k",
    "num_classes": 1000,
    "image_size": 224,
    "eval_resize_size": 256,
    "num_channels": 3,
    "mean": [0.485, 0.456, 0.406],
    "std": [0.229, 0.224, 0.225]
  },
  "model": {
    "architecture": "vit",
    "attention_variant": "layer_bbt",
    "latent_rank": 64,
    "image_size": 224,
    "patch_size": 16,
    "num_channels": 3,
    "hidden_size": 768,
    "num_hidden_layers": 12,
    "num_attention_heads": 12,
    "intermediate_size": 3072,
    "hidden_dropout_prob": 0.0,
    "attention_dropout_prob": 0.0
  },
  "initialization": {
    "query_key": "standard"
  },
  "training": {
    "max_epochs": 30,
    "per_device_batch_size": 256,
    "gradient_accumulation_steps": 2,
    "effective_batch_size": 512,
    "learning_rate": 0.003,
    "weight_decay": 0.05,
    "beta1": 0.9,
    "beta2": 0.999,
    "warmup_epochs": 5,
    "warmup_start_factor": 0.033,
    "num_workers": 8,
    "label_smoothing": 0.11,
    "use_amp": true,
    "eval_every_epochs": 1
  },
  "augmentation": {
    "mixup_alpha": 0.2,
    "cutmix_alpha": 1.0,
    "switch_prob": 0.5
  },
  "ema": {
    "enabled": false,
    "decay": 0.99998,
    "update_every_steps": 32
  },
  "regularization": {
    "enabled": false
  },
  "instrumentation": {
    "measure_training_time": true,
    "measure_flops": true,
    "measure_layer_ratios": false,
    "exclude_analysis_time": true,
    "exclude_analysis_flops": true
  }
}
