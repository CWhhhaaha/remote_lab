    "interval_config": "configs/priors/jigsaw_bert_small_encoder_manual_band_v1.json",
    "schedule": [
      {
        "epoch_start": 1,
        "epoch_end": 50,
        "every_n_epochs": 5
      },
      {
        "epoch_start": 51,
