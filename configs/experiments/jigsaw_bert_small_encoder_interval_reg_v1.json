  "model": {
    "family": "bert",
    "variant": "bert_small",
    "mode": "encoder",
    "num_hidden_layers": 4,
    "hidden_size": 256,
    "intermediate_size": 1024,
    "num_attention_heads": 4
  },
  "initialization": {
    "query_key": "standard"
  },
  "training": {
    "max_epochs": 200,
    "steps_per_epoch_estimate": 623.324219,
