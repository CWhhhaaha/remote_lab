{
  "experiment_name": "jigsaw-bert-small-encoder-interval-reg-v1",
  "notes": "4-layer Jigsaw run with manual asymmetry-ratio interval regularization.",
  "seed": 42,
  "dataset": {
    "name": "jigsaw",
    "task": "masked_language_modeling",
    "estimated_train_samples": 159571,
    "data_root": "data",
    "prepared_train_file": "data/processed/train/jigsaw.json.gz",
    "prepared_test_file": "data/processed/test/jigsaw.json.gz",
    "tokenized_train_file": "data/cache/jigsaw/train_tokens.pt",
    "tokenized_test_file": "data/cache/jigsaw/test_tokens.pt",
    "cache_dir": "data/cache"
