    "per_device_batch_size": 32,
    "gradient_accumulation_steps": 8,
    "effective_batch_size": 256,
    "learning_rate": 5e-05,
    "warmup_steps": 200,
    "weight_decay": 0.01,
    "mlm_probability": 0.15,
    "max_seq_length": 128,
    "num_workers": 2
