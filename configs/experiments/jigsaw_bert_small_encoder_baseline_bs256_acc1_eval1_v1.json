{
  "experiment_name": "jigsaw-bert-small-encoder-baseline-bs256-acc1-eval1-v1",
  "notes": "4-layer Jigsaw baseline with per-device batch size 256, grad accumulation 1, and eval every epoch.",
  "seed": 42,
  "dataset": {
    "name": "jigsaw",
    "task": "masked_language_modeling",
    "estimated_train_samples": 159571,
    "data_root": "data",
    "prepared_train_file": "data/processed/train/jigsaw.json.gz",
    "prepared_test_file": "data/processed/test/jigsaw.json.gz",
    "tokenized_train_file": "data/cache/jigsaw/train_tokens.pt",
